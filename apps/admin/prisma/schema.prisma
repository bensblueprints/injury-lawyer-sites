generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Attorney {
  id                   String               @id @default(cuid())
  name                 String
  firmName             String
  email                String               @unique
  phone                String
  notes                String?
  portalPassword       String?              // bcrypt hash — set by admin so attorney can log into /attorney portal
  createdAt            DateTime             @default(now())
  acceptedLeadTypes    LeadType[]
  sites                Site[]
  invoices             Invoice[]
  creditPurchases      LeadCreditPurchase[]
}

model Site {
  id           String    @id @default(cuid())
  domain       String    @unique
  practiceArea String
  city         String
  state        String
  costPerLead  Float     @default(0)
  attorneyId   String?
  attorney     Attorney? @relation(fields: [attorneyId], references: [id])
  leads        Lead[]
  createdAt    DateTime  @default(now())
}

model Lead {
  id             String     @id @default(cuid())
  domain         String
  siteId         String?
  site           Site?      @relation(fields: [siteId], references: [id])
  name           String
  phone          String
  email          String
  caseType       String
  message        String?
  status         LeadStatus @default(NEW)
  invoiceId      String?
  invoice        Invoice?   @relation(fields: [invoiceId], references: [id])
  conversationId String?    // ElevenLabs conversation ID for transcript lookup
  leadType       LeadType?
  createdAt      DateTime   @default(now())
}

enum LeadStatus {
  NEW
  CONTACTED
  SOLD
  ARCHIVED
}

model Invoice {
  id         String        @id @default(cuid())
  attorneyId String
  attorney   Attorney      @relation(fields: [attorneyId], references: [id])
  amount     Float
  status     InvoiceStatus @default(UNPAID)
  leads      Lead[]
  notes      String?
  createdAt  DateTime      @default(now())
  paidAt     DateTime?
}

enum InvoiceStatus {
  UNPAID
  PAID
}

enum LeadType {
  FORM_FILL
  AI_CALL
  HOT_TRANSFER
}

model LeadCreditPurchase {
  id              String   @id @default(cuid())
  attorneyId      String
  attorney        Attorney @relation(fields: [attorneyId], references: [id])
  leadType        LeadType
  quantity        Int
  unitPrice       Float
  subtotal        Float
  processingFee   Float
  totalCharged    Float
  paymentIntentId String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}
