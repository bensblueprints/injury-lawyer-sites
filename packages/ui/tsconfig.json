{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@injury/schema": ["../../packages/schema/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
